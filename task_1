import random
import timeit
import matplotlib.pyplot as plt

sizes = [10, 100, 500, 1000, 2000]
quick_times = []
insertion_times = []

print("\nЗадание 4: Сравнение времени")
for size in sizes:
    data = [random.randint(0, size * 10) for _ in range(size)]
    q_time = timeit.timeit(lambda: quicksort(data), number=50)
    quick_times.append(q_time)
    i_time = timeit.timeit(lambda: insertion_sort(data), number=50)
    insertion_times.append(i_time)
    
    print(f"Размер {size}: QuickSort {q_time:.5f} с, InsertionSort {i_time:.5f} с")

plt.figure(figsize=(10, 6))
plt.plot(sizes, quick_times, marker='o', label='Быстрая сортировка')
plt.plot(sizes, insertion_times, marker='s', label='Сортировка вставками')
plt.xlabel('Размер списка')
plt.ylabel('Время')
plt.title('Сравнение времени выполнения (50 запусков)')
plt.legend()
plt.grid(True)
plt.savefig('insertion.png')
plt.show()