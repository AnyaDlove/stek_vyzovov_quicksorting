def find_max_recursive(lst, left, right):
    if left == right:
        return lst[left]
    mid = (left + right) // 2
    max_left = find_max_recursive(lst, left, mid)
    max_right = find_max_recursive(lst, mid + 1, right)
    return max_left if max_left > max_right else max_right

def find_max(lst):
    if not lst:
        return None
    return find_max_recursive(lst, 0, len(lst) - 1)
